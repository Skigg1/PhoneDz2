<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".RecipeDetailActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Название блюда -->
            <TextView
                android:id="@+id/tvDetailName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Заголовок "Ингредиенты" -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ingredients_title"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <!-- Ингредиенты -->
            <TextView
                android:id="@+id/tvDetailIngredients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:layout_marginTop="8dp"
                android:padding="8dp"
                android:background="@android:drawable/list_selector_background"/>

            <!-- Заголовок "Приготовление" -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/steps_title"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <!-- Шаги приготовления -->
            <TextView
                android:id="@+id/tvDetailSteps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:layout_marginTop="8dp"
                android:padding="8dp"
                android:background="@android:drawable/list_selector_background"/>

            <Button
                android:id="@+id/btnPlayRecipeVoice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/play_recipe_voice"
                android:layout_marginTop="16dp"/>

            <Button
                android:id="@+id/btnWatchVideo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/watch_video"
                android:layout_marginTop="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Таймеры приготовления:"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"/>

            <!-- Таймер 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="Взбить яйца:"/>

                <TextView
                    android:id="@+id/timer1_display"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="01:00"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <Button
                    android:id="@+id/timer1_start"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Старт"/>

                <Button
                    android:id="@+id/timer1_pause"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Пауза"/>

                <Button
                    android:id="@+id/timer1_reset"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Сброс"/>
            </LinearLayout>

            <!-- Таймер 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="Жарить омлет:"/>

                <TextView
                    android:id="@+id/timer2_display"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="04:00"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <Button
                    android:id="@+id/timer2_start"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Старт"/>

                <Button
                    android:id="@+id/timer2_pause"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Пауза"/>

                <Button
                    android:id="@+id/timer2_reset"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Сброс"/>
            </LinearLayout>

            <!-- Таймер 3 (с возможностью настройки) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/timer3_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="Настоять чай (мин):"/>

                <TextView
                    android:id="@+id/timer3_display"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="03:00"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <Button
                    android:id="@+id/timer3_start"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Старт"/>

                <Button
                    android:id="@+id/timer3_pause"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Пауза"/>

                <Button
                    android:id="@+id/timer3_reset"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Сброс"/>
            </LinearLayout>

            <!-- Кнопка для вызова диалога настройки таймера 3 -->
            <Button
                android:id="@+id/btn_set_timer3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Настроить время таймера 3"
                android:layout_marginTop="8dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>