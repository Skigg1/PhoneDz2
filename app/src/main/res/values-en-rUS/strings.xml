    <!-- Шаги рецептов -->
    <string name="steps_omelette">1. Break the eggs into a deep bowl.\n
         2. Add salt.\n
         3. Use a fork or a whisk to mix until smooth.\n
         4. Pour in the milk.\n
         5. Mix thoroughly.\n
         6. Heat the vegetable oil in a frying pan over medium heat. Pour the egg mixture into the pan.\n
         7. Reduce the heat to low, cover the pan with a lid, and cook the omelette for about 5 minutes, until the eggs are set.</string>
    <string name="steps_soup">1. Boil chicken. 2. Add chopped veggies. 3. Add noodles. Cook.</string>
    <string name="steps_salmon">1. Season salmon. 2. Grill for 5-7 mins each side. 3. Serve with lemon.</string>

